<UserControl x:Class="WpfMusicPlayer.Views.EqualizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfMusicPlayer.ViewModels">
    <UserControl.Resources>
        <Style x:Key="EqSliderThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="ThumbEllipse" Fill="#0078D7" Width="14" Height="14"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ThumbEllipse" Property="Fill" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EqSliderStyle" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="-12"/>
            <Setter Property="Maximum" Value="12"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="MinHeight" Value="80"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Background="#30FFFFFF" Height="1" VerticalAlignment="Center" Margin="2,0"/>
                            <Border Background="#40FFFFFF" Width="3" HorizontalAlignment="Center" CornerRadius="1.5"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EqSliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EqValueTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="MaxLength" Value="3"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="Transparent" BorderBrush="Transparent"
                                BorderThickness="0,0,0,1" Padding="2,1" CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="均衡器" Foreground="White" FontSize="18" FontWeight="SemiBold"
                   Margin="4,4,0,12"/>

        <Grid Grid.Row="1" Margin="4,0,4,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="预设" Foreground="#BBBBBB" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Grid Grid.Column="1">
                <ComboBox ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                          DisplayMemberPath="Name">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#30FFFFFF"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="FontSize" Value="13"/>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>
                <TextBlock Text="自定义" IsHitTestVisible="False"
                           Foreground="#30000000" FontSize="13"
                           VerticalAlignment="Center" Margin="9,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPreset}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Bands}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:EqualizerBandViewModel}">
                    <Grid Margin="0,0,0,4" IsEnabled="{Binding IsEnabled}">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                        <Setter Property="Opacity" Value="0.42"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Slider Grid.Row="0" Style="{StaticResource EqSliderStyle}"
                                Value="{Binding Value, Mode=TwoWay}"
                                HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Text="{Binding DisplayValue}" Foreground="#AADDDDDD" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBox Grid.Row="2" Style="{StaticResource EqValueTextBox}"
                                 Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                 GotKeyboardFocus="ValueTextBox_GotFocus"
                                 KeyDown="ValueTextBox_KeyDown"
                                 Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="3" Text="{Binding Label}" Foreground="#88DDDDDD" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
